{
    "__inputs": [
        {
            "name": "DS_PROMETHEUS",
            "label": "Prometheus",
            "description": "",
            "type": "datasource",
            "pluginId": "prometheus",
            "pluginName": "Prometheus"
        }
    ],
    "annotations": {
        "list": []
    },
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 1,
    "id": null,
    "links": [],
    "panels": [
        {
            "id": 1,
            "title": "Request Rate (req/s)",
            "type": "timeseries",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
            "targets": [
                {
                    "expr": "sum(rate(api_requests_total{job=\"face-recognition-api\"}[1m])) by (method, endpoint)",
                    "legendFormat": "{{method}} {{endpoint}}"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "reqps",
                    "color": { "mode": "palette-classic" }
                }
            }
        },
        {
            "id": 2,
            "title": "P95 Latency (ms)",
            "type": "timeseries",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
            "targets": [
                {
                    "expr": "histogram_quantile(0.95, sum(rate(api_request_latency_seconds_bucket{job=\"face-recognition-api\"}[5m])) by (le, endpoint)) * 1000",
                    "legendFormat": "p95 {{endpoint}}"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "ms",
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            { "color": "green", "value": null },
                            { "color": "yellow", "value": 300 },
                            { "color": "red", "value": 500 }
                        ]
                    }
                }
            }
        },
        {
            "id": 3,
            "title": "Error Rate (%)",
            "type": "timeseries",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
            "targets": [
                {
                    "expr": "sum(rate(api_requests_total{job=\"face-recognition-api\", status=~\"5..\"}[1m])) / sum(rate(api_requests_total{job=\"face-recognition-api\"}[1m])) * 100",
                    "legendFormat": "Error %"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "percent",
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            { "color": "green", "value": null },
                            { "color": "red", "value": 1 }
                        ]
                    }
                }
            }
        },
        {
            "id": 4,
            "title": "Prediction Latency (avg ms)",
            "type": "gauge",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
            "targets": [
                {
                    "expr": "rate(prediction_latency_seconds_sum{job=\"face-recognition-api\"}[5m]) / rate(prediction_latency_seconds_count{job=\"face-recognition-api\"}[5m]) * 1000",
                    "legendFormat": "Avg Prediction Latency"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "ms",
                    "min": 0,
                    "max": 2000,
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            { "color": "green", "value": null },
                            { "color": "yellow", "value": 500 },
                            { "color": "red", "value": 1000 }
                        ]
                    }
                }
            }
        },
        {
            "id": 5,
            "title": "Predictions / minute",
            "type": "stat",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
            "targets": [
                {
                    "expr": "sum(increase(predictions_total{job=\"face-recognition-api\"}[1m]))",
                    "legendFormat": "Predictions"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "color": { "mode": "thresholds" },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            { "color": "blue", "value": null }
                        ]
                    }
                }
            }
        },
        {
            "id": 6,
            "title": "Face Detection Rate",
            "type": "timeseries",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
            "targets": [
                {
                    "expr": "sum(rate(face_detections_total{detected=\"True\", job=\"face-recognition-api\"}[5m])) / sum(rate(face_detections_total{job=\"face-recognition-api\"}[5m])) * 100",
                    "legendFormat": "Detection Rate %"
                },
                {
                    "expr": "sum(rate(face_detections_total{detected=\"False\", job=\"face-recognition-api\"}[5m])) / sum(rate(face_detections_total{job=\"face-recognition-api\"}[5m])) * 100",
                    "legendFormat": "No Face %"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "percent"
                }
            }
        },
        {
            "id": 7,
            "title": "Prediction Status Breakdown",
            "type": "timeseries",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
            "targets": [
                {
                    "expr": "sum(rate(predictions_total{job=\"face-recognition-api\"}[5m])) by (status)",
                    "legendFormat": "{{status}}"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "ops",
                    "color": { "mode": "palette-classic" }
                }
            }
        },
        {
            "id": 8,
            "title": "Host CPU Usage",
            "type": "timeseries",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
            "targets": [
                {
                    "expr": "100 - (avg(irate(node_cpu_seconds_total{mode=\"idle\", job=\"node\"}[5m])) * 100)",
                    "legendFormat": "CPU Usage %"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "percent",
                    "min": 0,
                    "max": 100
                }
            }
        },
        {
            "id": 9,
            "title": "Host Memory Usage",
            "type": "timeseries",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
            "targets": [
                {
                    "expr": "(node_memory_MemTotal_bytes{job=\"node\"} - node_memory_MemAvailable_bytes{job=\"node\"}) / node_memory_MemTotal_bytes{job=\"node\"} * 100",
                    "legendFormat": "Memory Usage %"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "percent",
                    "min": 0,
                    "max": 100
                }
            }
        }
    ],
    "schemaVersion": 38,
    "tags": [
        "face-recognition",
        "api",
        "mlops"
    ],
    "title": "Face Recognition API Dashboard",
    "uid": "face-recognition-api",
    "version": 2
}