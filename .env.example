# Application
APP_NAME=face-recognition-mlops
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
CORS_ORIGINS=["http://localhost:3000"]

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=face_recognition
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme123
DATABASE_URL=postgresql+asyncpg://admin:changeme123@localhost:5432/face_recognition


# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_ACCESS_LOGS=access-logs
KAFKA_TOPIC_EVENTS=events
KAFKA_TOPIC_ALERTS=alerts
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_DISCORD_WEBHOOK_HERE

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_RAW=raw-images
MINIO_BUCKET_PROCESSED=processed-data
MINIO_SECURE=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Prometheus
PROMETHEUS_PORT=9090

# Jaeger
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831
JAEGER_OTLP_ENDPOINT=http://localhost:4317

# Airflow
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=46BKJoQYlPPOexq0OhDZnIlNepKFf87WFwLt0efcogo=
AIRFLOW_SECRET_KEY=face-recognition-mlops-secret

# Triton Inference Server
TRITON_URL=localhost:8001
TRITON_MODEL_NAME=facenet
TRITON_MODEL_VERSION=1

# Feast Feature Store
FEAST_REDIS_HOST=localhost
FEAST_REDIS_PORT=6379
FEAST_POSTGRES_HOST=localhost
FEAST_POSTGRES_PORT=5432


# Model Configuration
MODEL_NAME=facenet
MODEL_THRESHOLD=0.6
MAX_IMAGE_SIZE_MB=10
ALLOWED_EXTENSIONS=["jpg","jpeg","png"]


